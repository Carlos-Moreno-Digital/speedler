FROM evershop/evershop:latest

# Create directories
RUN mkdir -p /app/translations/es /app/media/speedler

# Copy translations
COPY translations/es /app/translations/es

# Copy logo
COPY public/logo.png /app/media/speedler/logo.png

# Copy config (WITHOUT theme to avoid build issues)
COPY config /app/config

# Copy setup scripts
COPY *.cjs /app/

# Copy CSV
COPY ProductosPropios.csv /app/

EXPOSE 3000
CMD ["npm", "run", "start"]
